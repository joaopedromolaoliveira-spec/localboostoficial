# =====================================================================
# rizrmd/whatsapp-web-api — variáveis de ambiente
# Cole esses nomes/valores no painel de Variables do Railway (ou similar).
# =====================================================================

# Porta HTTP do servidor (Railway define automaticamente via $PORT; deixe 8080 se for VPS)
PORT=8080

# String de conexão do PostgreSQL.
# No Railway: crie um plugin PostgreSQL e use ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://usuario:senha@host:5432/whatsapp_db

# URL que vai receber os webhooks de mensagens recebidas.
# Aponte para o endpoint público do seu app Lovable:
WA_WEBHOOK_URL=https://localboostoficial.lovable.app/api/public/webhooks/waha

# CORS — libere o domínio do frontend para o navegador poder chamar direto.
# O binário rizrmd/whatsapp-web-api não tem flag de CORS embutida;
# se precisar, coloque um proxy (Caddy/Nginx) na frente adicionando:
#   Access-Control-Allow-Origin: *
#   Access-Control-Allow-Methods: GET,POST,OPTIONS
#   Access-Control-Allow-Headers: Content-Type
